<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient"
    android:padding="16dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/balance_format"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/cashControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvBalance">

        <Button
            android:id="@+id/btnCashIn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Cash In ₱100" />

        <Button
            android:id="@+id/btnCashOut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cash Out" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/diceContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/cashControls">

        <TextView
            android:id="@+id/tvDie1"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@color/gray_placeholder"
            android:gravity="center"
            android:text="?"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/tvDie2"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@color/gray_placeholder"
            android:gravity="center"
            android:text="?"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/tvDie3"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:background="@color/gray_placeholder"
            android:gravity="center"
            android:text="?"
            android:textSize="30sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSelectedColorInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Select a color to bet"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/diceContainer" />

    <GridLayout
        android:id="@+id/colorGrid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:columnCount="3"
        android:rowCount="2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSelectedColorInfo">

        <Button
            android:id="@+id/btnRed"
            android:layout_width="90dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:backgroundTint="@color/game_red"
            android:text="@string/red" />

        <Button
            android:id="@+id/btnBlue"
            android:layout_width="90dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:backgroundTint="@color/game_blue"
            android:text="@string/blue" />

        <Button
            android:id="@+id/btnGreen"
            android:layout_width="90dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:backgroundTint="@color/game_green"
            android:text="@string/green" />

        <Button
            android:id="@+id/btnYellow"
            android:layout_width="90dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:backgroundTint="@color/game_yellow"
            android:text="@string/yellow"
            android:textColor="@color/black" />

        <Button
            android:id="@+id/btnWhite"
            android:layout_width="90dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:backgroundTint="@color/game_white"
            android:text="@string/white"
            android:textColor="@color/black" />

        <Button
            android:id="@+id/btnViolet"
            android:layout_width="90dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:backgroundTint="@color/game_violet"
            android:text="@string/violet" />
    </GridLayout>

    <LinearLayout
        android:id="@+id/bettingControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/colorGrid">

        <Button
            android:id="@+id/btnDecreaseBet"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="-" />

        <EditText
            android:id="@+id/etBetAmount"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:gravity="center"
            android:hint="Bet"
            android:inputType="numberDecimal"
            android:text="1.00"
            android:textColor="@color/black" />

        <Button
            android:id="@+id/btnIncreaseBet"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="+" />
    </LinearLayout>

    <Button
        android:id="@+id/btnRoll"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:text="@string/roll"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/bettingControls" />

    <TextView
        android:id="@+id/tvHistoryHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/history_title"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnRoll" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHistoryHeader">

        <TextView
            android:id="@+id/tvHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:textColor="@color/black"
            android:textSize="14sp" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
